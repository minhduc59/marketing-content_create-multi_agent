# Database
DATABASE_URL=postgresql+asyncpg://scanner:scanner_pass@localhost:5432/trending_scanner

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-xxx

# YouTube Data API v3
YOUTUBE_API_KEY=

# RapidAPI (TikTok, Twitter, Instagram)
RAPIDAPI_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# BFL (Black Forest Labs) — FLUX.2 image generation
BFL_API_KEY=

# Cloudinary (temporary image hosting; will be replaced by S3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# App
APP_ENV=development
LOG_LEVEL=INFO

# NestJS backend gateway (added for multi-user support)
# Local dev: http://localhost:3000
# Docker Compose: http://backend:3000  ← use the service name, not localhost
# IMPORTANT: "[Errno -2] Name or service not known" means this value is wrong for your env
BACKEND_ORIGIN=http://localhost:3000
INTERNAL_API_KEY=
REQUIRE_INTERNAL_AUTH=false
