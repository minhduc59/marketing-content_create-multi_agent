# NestJS Backend Gateway configuration

# Database — backend role has full write on `app` schema and narrow
# read+write access to `ai` schema. See docker/init-db.sql for role setup.
DATABASE_URL=postgresql://backend_svc:backend_pass@localhost:5432/trending_scanner?schema=app

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Upstream ai-service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_API_KEY=change-me-internal

# Zernio TikTok publishing (https://docs.zernio.com)
# Base URL of this backend — used to build the OAuth callback redirect URL.
# In production set this to your public backend hostname (e.g. https://api.myapp.com).
TIKTOK_CALLBACK_BASE_URL=http://localhost:3000
#
# API key from the Zernio dashboard. Format: sk_<64 hex chars>
ZERNIO_API_KEY=
# Secret configured when registering the webhook in Zernio (HMAC-SHA256)
ZERNIO_WEBHOOK_SECRET=
# Optional override for Zernio base URL
ZERNIO_BASE_URL=https://zernio.com/api/v1
#
# One-time webhook registration:
#   curl -X POST https://zernio.com/api/v1/webhooks \
#     -H "Authorization: Bearer $ZERNIO_API_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{
#       "url": "https://<your-public-host>/v1/publisher/webhooks",
#       "events": ["post.published","post.failed","post.partial",
#                  "post.scheduled","post.cancelled",
#                  "account.connected","account.disconnected"],
#       "secret": "'"$ZERNIO_WEBHOOK_SECRET"'"
#     }'
# In local dev, expose the backend via ngrok / cloudflared and use that URL.

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3001

# App
PORT=3000
NODE_ENV=development
